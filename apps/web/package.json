{
  "name": "@wlpapp/web",
  "private": true,
  "version": "0.1.0",
  "description": "WLPApp web scaffold",
  "scripts": {
    "dev": "node -e \"const port=process.env.PORT || 3000; const cmd=process.platform==='win32'?'next.cmd':'next'; require('child_process').spawn(cmd,['dev','-p',String(port)],{stdio:'inherit'}).on('exit',(code)=>process.exit(code ?? 0));\"",
    "build": "next build"
  },
  "dependencies": {
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}
